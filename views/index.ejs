<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Bộ sưu tập các nhân vật Nintendo huyền thoại." />
  <title>Nintendo Characters Collection</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

<!-- ── Header ─────────────────────────────────────── -->
<header class="site-header">
  <h1>🎮 Nintendo Collection</h1>
  <p class="subtitle">
    Bộ sưu tập nhân vật huyền thoại
    <span class="header-badge"><%= characters.length %> nhân vật</span>
  </p>
</header>

<!-- ── Controls ───────────────────────────────────── -->
<%
  const seriesList = [...new Set(characters.map(c => c.game_series).filter(Boolean))].sort();
  const playableCount = characters.filter(c => c.is_playable).length;
  const seriesCount   = seriesList.length;

  // Image map - ảnh được phục vụ local từ /public/uploads/
  // Để thay ảnh: đặt file vào public/uploads/ và đổi đường dẫn tương ứng
  const imageMap = {
    'Mario':           '/uploads/mario.png',
    'Link':            '/uploads/link.png',
    'Samus Aran':      '/uploads/samus.png',
    'Donkey Kong':     '/uploads/donkey_kong.png',
    'Princess Zelda':  '/uploads/princess_zelda.png',
    'Bowser':          '/uploads/bowser.png',
    'Kirby':           '/uploads/kirby.png',
    'Pikachu':         '/uploads/pikachu.png',
    'Fox McCloud':     '/uploads/fox_mccloud.png',
    'Captain Falcon':  '/uploads/captain_falcon.png',
  };
%>

<div class="controls">
  <!-- Thống kê -->
  <div class="stat-bar">
    <div class="stat">
      <span class="stat-number"><%= characters.length %></span>
      <span class="stat-label">Nhân vật</span>
    </div>
    <div class="stat">
      <span class="stat-number"><%= playableCount %></span>
      <span class="stat-label">Playable</span>
    </div>
    <div class="stat">
      <span class="stat-number"><%= seriesCount %></span>
      <span class="stat-label">Series</span>
    </div>
  </div>

  <!-- Filter -->
  <div class="filter-group">
    <button class="filter-btn active" data-series="all">Tất cả</button>
    <% seriesList.forEach(series => { %>
      <button class="filter-btn" data-series="<%= series %>"><%= series %></button>
    <% }); %>
  </div>
</div>

<!-- ── Card Grid ───────────────────────────────────── -->
<main class="collection" id="collection">
  <% characters.forEach(char => { %>
    <%
      const imgSrc = imageMap[char.name] || '';
      const safeDesc = (char.description || '').replace(/'/g, "&#39;");
    %>
    <article
      class="card"
      data-series="<%= char.game_series %>"
      data-name="<%= char.name %>"
      data-series-full="<%= char.game_series %>"
      data-year="<%= char.debut_year %>"
      data-desc="<%= safeDesc %>"
      data-playable="<%= char.is_playable %>"
      data-img="<%= imgSrc %>"
      role="button"
      tabindex="0"
      aria-label="Xem chi tiết <%= char.name %>"
    >
      <div class="card-img-wrap">
        <img
          data-src="<%= imgSrc %>"
          alt="<%= char.name %>"
          loading="lazy"
        />
        <span class="playable-badge <%= char.is_playable ? '' : 'npc' %>">
          <%= char.is_playable ? '▶ PLAYER' : 'NPC' %>
        </span>
      </div>
      <div class="card-body">
        <p class="card-name"><%= char.name %></p>
        <p class="card-series"><%= char.game_series %></p>
        <p class="card-year">Since <%= char.debut_year %></p>
      </div>
    </article>
  <% }); %>

  <div class="no-results" style="display:none;">
    Không có nhân vật nào trong series này.
  </div>
</main>

<!-- ── Modal ───────────────────────────────────────── -->
<div class="modal-overlay" id="modal-overlay" role="dialog" aria-modal="true">
  <div class="modal" style="position:relative;">
    <button class="modal-close" id="modal-close" aria-label="Đóng">✕</button>
    <div class="modal-header">
      <img id="modal-img" src="" alt="" class="modal-img" />
      <div>
        <h2 class="modal-title" id="modal-title"></h2>
        <p class="modal-series" id="modal-series"></p>
      </div>
    </div>
    <div class="modal-body">
      <p class="modal-desc" id="modal-desc"></p>
      <div class="modal-meta">
        <div class="meta-tag" id="modal-year"></div>
        <div class="meta-tag" id="modal-play"></div>
      </div>
    </div>
  </div>
</div>

<!-- ── Footer ─────────────────────────────────────── -->
<footer>
  Nintendo Collection &copy; <%= new Date().getFullYear() %> &mdash;
  Dữ liệu từ PostgreSQL HA Cluster (VIP: <%= process.env.DB_HOST %>)
</footer>

<script src="/js/main.js"></script>
</body>
</html>
